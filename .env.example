# SevaLink Landing Page — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# Site URL — used for OG tags, canonical URLs, sitemap
NEXT_PUBLIC_SITE_URL=https://www.sevalink.in

# App Store links — set once apps are published
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/sevalink/id000000000
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=in.sevalink.app

# Support phone — used in contact page and Call Now button
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210
NEXT_PUBLIC_SUPPORT_PHONE_DISPLAY=+91 98765 43210

# Google Analytics 4 (optional — uncomment in layout.tsx when ready)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
